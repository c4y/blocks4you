{% extends "@Contao/be_main" %}

{% block headline %}{{ headline }}{% endblock %}

{% block error %}
    {% if error is defined %}
        <div class="tl_error">
            <p>{{ error }}</p>
        </div>
    {% endif %}
{% endblock %}

{% block main %}
    {% if error is not defined %}
        <div class="tl_listing_container">
            {% if blocks is empty %}
                <div class="tl_info">
                    <p>Kein block verfügbar.</p>
                </div>
            {% else %}
                <div class="blocks-grid">
                    {% for block in blocks %}
                        <div class="blocks-card">
                            <h3 style="margin-top: 0; color: #333;">{{ block.name }}</h3>
                            <p style="color: #666; margin: 10px 0;">{{ block.description }}</p>
                            <p style="font-size: 12px; color: #999;">
                                <strong>Elemente:</strong> {{ block.blocks|length }}
                            </p>
                            
                            {% if block.preview %}
                                <div class="blocks-preview">
                                    <img src="{{ block.preview }}" 
                                         alt="Vorschau für {{ block.name }}" >
                                </div>
                            {% endif %}
                            
                            <a href="/contao/blocks?do={{ do }}&table={{ table }}&id={{ articleId }}&pid={{ pid }}&blockId={{ block.id }}&doBlockPaste=1&mode={{ mode }}" 
                               class="tl_submit" 
                               style="display: inline-block; margin-top: 10px; text-decoration: none;">
                                Auswählen
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
            
            <div style="margin-top: 30px;">
                <a href="javascript:history.go(-1)" class="tl_submit">
                    Zurück
                </a>
            </div>
        </div>
    {% endif %}
{% endblock %}
